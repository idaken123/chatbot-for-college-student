page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

button {
  margin: 0;
  padding: 0;
  background-color: transparent;
  border: none;
  line-height: normal;
}

button::after {
  border: none;
}
