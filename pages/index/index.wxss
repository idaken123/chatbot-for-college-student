.container {
  position: relative;
  height: 100vh;
  overflow: hidden;
}

.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.content-layer {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.header-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: white;
  border-bottom: 1rpx solid #eee;
}

.robot-info {
  display: flex;
  align-items: center;
}

.robot-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.robot-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.clear-btn {
  padding: 10rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
}

.clear-btn text {
  font-size: 24rpx;
  color: #666;
}

.chat-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  background-color: rgba(255, 255, 255, 0.9);
}

.message {
  display: flex;
  margin-bottom: 20rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin: 0 10rpx;
  flex-shrink: 0;
  opacity: 0.9;
}

.content {
  max-width: 70%;
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
}

.message.user .content {
  color: white;
  background-color: rgba(76, 175, 80, 0.9);
}

.input-area {
  display: flex;
  padding: 20rpx;
  border-top: 2rpx solid;
}

.input-area input {
  flex: 1;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 32rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
}

.input-area button {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  color: white;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.send-btn.disabled {
  opacity: 0.6;
}
