.container {
  padding: 20rpx;
  min-height: 100vh;
}

.section {
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid;
}

.theme-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.theme-item {
  width: calc(50% - 10rpx);
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  position: relative;
  border: 2rpx solid transparent;
}

.theme-item.active {
  border: 2rpx solid;
}

.theme-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.theme-name {
  font-size: 28rpx;
}

.check-icon {
  position: absolute;
  right: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  position: relative;
  border: 2rpx solid transparent;
}

.role-item.active {
  border: 2rpx solid;
}

.role-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.role-actions {
  display: flex;
  gap: 20rpx;
  margin-left: auto;
  margin-right: 40rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.edit-btn {
  background-color: rgba(76, 175, 80, 0.1);
}

.delete-btn {
  background-color: rgba(255, 77, 79, 0.1);
}

.add-role {
  border: 2rpx dashed;
  cursor: pointer;
}

.add-avatar {
  font-size: 40rpx;
}

.add-role:hover {
  opacity: 0.8;
}

.role-info {
  display: flex;
  flex-direction: column;
}

.role-name {
  font-size: 30rpx;
  font-weight: 500;
}

.role-desc {
  font-size: 24rpx;
  margin-top: 6rpx;
}

.action-list {
  display: flex;
  flex-direction: column;
}

.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid;
}

.action-item:last-child {
  border-bottom: none;
}

.action-text {
  font-size: 28rpx;
}

.action-arrow {
  font-size: 36rpx;
}

.about {
  text-align: center;
}

.about-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 26rpx;
  line-height: 1.8;
}
