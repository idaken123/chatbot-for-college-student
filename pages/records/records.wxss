.container {
  padding: 20rpx;
  min-height: 100vh;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
}

.summary-card {
  border-radius: 20rpx;
  padding: 30rpx;
  color: white;
  margin-bottom: 30rpx;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: bold;
}

.summary-icon {
  font-size: 36rpx;
}

.summary-content {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
}

.summary-suggestion {
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
}

.section-title {
  font-size: 30rpx;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.records-list {
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
}

.record-emoji {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-date {
  font-size: 30rpx;
  font-weight: 500;
}

.record-emotions {
  font-size: 24rpx;
  margin-top: 6rpx;
}

.record-right {
  display: flex;
  align-items: center;
}

.record-score {
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 10rpx;
}

.record-arrow {
  font-size: 36rpx;
}
